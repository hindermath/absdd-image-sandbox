{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "dependencyDashboard": true,
  "automerge": false,
  "platformAutomerge": false,
  "prConcurrentLimit": 5,
  "prHourlyLimit": 2,
  "labels": [
    "dependencies",
    "security"
  ],
  "enabledManagers": [
    "custom.regex"
  ],
  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/^Dockerfile$/"
      ],
      "matchStrings": [
        "# renovate: datasource=(?<datasource>[a-zA-Z0-9._-]+) depName=(?<depName>[^\\s]+)(?: packageName=(?<packageName>[^\\s]+))?(?: versioning=(?<versioning>[^\\s]+))? argName=(?<argName>[A-Z][A-Z0-9_]*)\\s+ARG [A-Z][A-Z0-9_]*=(?<currentValue>[^\\s]+)"
      ],
      "depTypeTemplate": "dockerfile-arg"
    },
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/^home-baseline\\.lock\\.json$/"
      ],
      "matchStrings": [
        "\\\"tag\\\": \\\"(?<currentValue>v[0-9]+\\.[0-9]+\\.[0-9]+)\\\",\\s+\\\"commit\\\": \\\"(?<currentDigest>[0-9a-f]{40})\\\""
      ],
      "datasourceTemplate": "github-tags",
      "depNameTemplate": "home-baseline",
      "packageNameTemplate": "hindermath/home-baseline",
      "versioningTemplate": "semver",
      "depTypeTemplate": "embedded-content"
    }
  ],
  "packageRules": [
    {
      "matchManagers": [
        "custom.regex"
      ],
      "matchDepTypes": [
        "dockerfile-arg"
      ],
      "addLabels": [
        "dockerfile-arg"
      ],
      "commitMessageTopic": "{{depName}} Dockerfile ARG"
    },
    {
      "matchManagers": [
        "custom.regex"
      ],
      "matchDepTypes": [
        "embedded-content"
      ],
      "addLabels": [
        "embedded-content",
        "home-baseline"
      ],
      "commitMessageTopic": "{{depName}} embedded reference"
    },
    {
      "matchPackageNames": [
        "golang.org/x/tools/gopls",
        "honnef.co/go/tools",
        "golang.org/x/vuln",
        "github.com/go-delve/delve"
      ],
      "groupName": "Go tooling Dockerfile ARGs",
      "addLabels": [
        "go"
      ]
    },
    {
      "matchPackageNames": [
        "opencode-ai",
        "@openai/codex",
        "@anthropic-ai/claude-code",
        "@google/gemini-cli",
        "google-antigravity/antigravity-cli",
        "@github/copilot"
      ],
      "groupName": "agent CLI Dockerfile ARGs",
      "addLabels": [
        "agent-tools"
      ]
    },
    {
      "matchPackageNames": [
        "rust",
        "rust-lang/rustup"
      ],
      "groupName": "Rust tooling Dockerfile ARGs",
      "addLabels": [
        "rust"
      ]
    },
    {
      "matchPackageNames": [
        "swift"
      ],
      "groupName": "Swift tooling Dockerfile ARGs",
      "addLabels": [
        "swift"
      ]
    },
    {
      "matchPackageNames": [
        "anchore/syft"
      ],
      "groupName": "supply-chain tooling Dockerfile ARGs",
      "addLabels": [
        "supply-chain",
        "sbom"
      ]
    }
  ]
}
